{
  "name": "@braudypedrosa/bp-search-widget",
  "version": "1.1.0",
  "description": "Framework-agnostic vacation rental search widget powered by bp-calendar",
  "type": "module",
  "main": "./bp-search-widget.js",
  "module": "./bp-search-widget.js",
  "exports": {
    ".": "./bp-search-widget.js",
    "./styles": "./dist/bp-search-widget.css"
  },
  "files": [
    "bp-search-widget.js",
    "dist/bp-search-widget.css",
    "bp-search-widget.scss",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "search-widget",
    "vacation-rental",
    "booking",
    "datepicker",
    "javascript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braudypedrosa/bp-search-widget.git"
  },
  "bugs": {
    "url": "https://github.com/braudypedrosa/bp-search-widget/issues"
  },
  "homepage": "https://github.com/braudypedrosa/bp-search-widget#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:css": "node ./scripts/build-css.mjs",
    "dev": "vite",
    "test": "vitest run",
    "release": "npm run build:css && bash ./scripts/release.sh",
    "release:patch": "npm run build:css && bash ./scripts/release.sh patch",
    "release:minor": "npm run build:css && bash ./scripts/release.sh minor",
    "release:major": "npm run build:css && bash ./scripts/release.sh major",
    "release:npm": "npm publish"
  },
  "dependencies": {
    "@braudypedrosa/bp-calendar": "^1.0.5",
    "@braudypedrosa/bp-ui-components": "^0.3.0"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-free": ">=6.0.0"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "sass-embedded": "^1.97.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
